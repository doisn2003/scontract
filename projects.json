  "name": "Truy xuất nguồn gốc Nông sản",
  "description": "Ghi lại lịch sử phát triển nông sản từ nông trại đến tay người tiêu dùng",
  "network": "bsc-testnet",
  "contracts": [
    {
      "name": "Traceability",
      "soliditySource": "// SPDX-License-Identifier: MIT\npragma solidity ^0.8.20;\n\nimport \"hardhat/console.sol\";\n\ncontract Traceability {\n    // Định nghĩa các trạng thái bắt buộc theo tuần tự\n    enum State { Created, Processed, Verified, Stocked, Sold }\n\n    struct Batch {\n        uint256 id;\n        // 1. Farm\n        string farmItem;    \n        string farmOrigin;  \n        // 2. Processing\n        string procItem;    \n        string procCompany; \n        // 3. Quality\n        string certHash;    \n        // 4. Warehouse\n        string wareName;    \n        // 5. Supermarket\n        string martName;    \n        string finalName;   \n        \n        State currentState; // Trạng thái hiện tại của lô hàng\n    }\n\n    mapping(uint256 => Batch) public batches;\n    uint256 public batchCount;\n\n    // Mapping hỗ trợ tìm kiếm cho Người tiêu dùng: Tên SP -> Danh sách ID lô hàng\n    mapping(string => uint256[]) public productToBatchIds;\n    // Mảng lưu danh sách tên các sản phẩm đã bán ra thị trường (để hiện lên SelectBox)\n    string[] public soldProductNames; \n    mapping(string => bool) private isProductNameExists; // Check trùng để không add 2 lần vào list selectbox\n\n    // HARDCODE VÍ\n    address constant WALLET_FARM = 0x68AE12D61a69497EDA1C7568c982e6CF7E8921FE;\n    address constant WALLET_PROC = 0x68AE12D61a69497EDA1C7568c982e6CF7E8921FE;\n    address constant WALLET_QUAL = 0x68AE12D61a69497EDA1C7568c982e6CF7E8921FE;\n    address constant WALLET_WARE = 0x68AE12D61a69497EDA1C7568c982e6CF7E8921FE;\n    address constant WALLET_MART = 0x68AE12D61a69497EDA1C7568c982e6CF7E8921FE;\n\n    event BatchHistory(uint256 indexed id, string action);\n\n    // 1. FARM: Tạo lô hàng\n    function createBatch(string memory _farmItem, string memory _origin) public {\n        require(msg.sender == WALLET_FARM, \"Access Denied: Farm Only\");\n        \n        batchCount++;\n        Batch storage b = batches[batchCount];\n        b.id = batchCount;\n        b.farmItem = _farmItem;\n        b.farmOrigin = _origin;\n        b.currentState = State.Created;\n\n        emit BatchHistory(batchCount, \"Created\");\n    }\n\n    // 2. PROCESSING: Chỉ chạy khi State == Created\n    function processBatch(uint256 _id, string memory _procItem, string memory _company) public {\n        require(msg.sender == WALLET_PROC, \"Access Denied: Processing Only\");\n        require(batches[_id].currentState == State.Created, \"Sequence Error: Batch must be Created first\");\n\n        Batch storage b = batches[_id];\n        b.procItem = _procItem;\n        b.procCompany = _company;\n        b.currentState = State.Processed;\n\n        emit BatchHistory(_id, \"Processed\");\n    }\n\n    // 3. QUALITY: Chỉ chạy khi State == Processed\n    function verifyBatch(uint256 _id) public {\n        require(msg.sender == WALLET_QUAL, \"Access Denied: Quality Only\");\n        require(batches[_id].currentState == State.Processed, \"Sequence Error: Batch must be Processed first\");\n\n        Batch storage b = batches[_id];\n        // Tạo mã hash giả lập\n        b.certHash = toAsciiString(keccak256(abi.encodePacked(_id, block.timestamp, msg.sender)));\n        b.currentState = State.Verified;\n\n        emit BatchHistory(_id, \"Verified\");\n    }\n\n    // 4. WAREHOUSE: Chỉ chạy khi State == Verified\n    function stockBatch(uint256 _id, string memory _wareName) public {\n        require(msg.sender == WALLET_WARE, \"Access Denied: Warehouse Only\");\n        require(batches[_id].currentState == State.Verified, \"Sequence Error: Batch must be Verified first\");\n\n        Batch storage b = batches[_id];\n        b.wareName = _wareName;\n        b.currentState = State.Stocked;\n\n        emit BatchHistory(_id, \"Stocked\");\n    }\n\n    // 5. SUPERMARKET: Chỉ chạy khi State == Stocked. Đây là bước CHỐT tên sản phẩm.\n    function sellBatch(uint256 _id, string memory _martName, string memory _finalName) public {\n        require(msg.sender == WALLET_MART, \"Access Denied: Supermarket Only\");\n        require(batches[_id].currentState == State.Stocked, \"Sequence Error: Batch must be Stocked first\");\n\n        Batch storage b = batches[_id];\n        b.martName = _martName;\n        b.finalName = _finalName;\n        b.currentState = State.Sold;\n\n        // Logic phục vụ tìm kiếm: Lưu ID vào danh sách của tên SP này\n        productToBatchIds[_finalName].push(_id);\n\n        // Nếu tên SP này chưa từng có trong danh sách SelectBox thì thêm vào\n        if (!isProductNameExists[_finalName]) {\n            soldProductNames.push(_finalName);\n            isProductNameExists[_finalName] = true;\n        }\n\n        emit BatchHistory(_id, \"Sold\");\n    }\n\n    // --- GETTERS ---\n\n    function getBatch(uint256 _id) public view returns (Batch memory) {\n        return batches[_id];\n    }\n\n    // Lấy danh sách tên sản phẩm để đổ vào SelectBox\n    function getAllProductNames() public view returns (string[] memory) {\n        return soldProductNames;\n    }\n\n    // Lấy danh sách ID lô hàng của một tên sản phẩm cụ thể\n    function getBatchIdsByProductName(string memory _name) public view returns (uint256[] memory) {\n        return productToBatchIds[_name];\n    }\n\n    // Helper: Bytes32 to String\n    function toAsciiString(bytes32 x) internal pure returns (string memory) {\n        bytes memory s = new bytes(64);\n        for (uint i = 0; i < 32; i++) {\n            bytes1 b = bytes1(uint8(uint(x) / (2**(8*(31 - i)))));\n            bytes1 hi = bytes1(uint8(b) / 16);\n            bytes1 lo = bytes1(uint8(b) - 16 * uint8(hi));\n            s[2*i] = char(hi);\n            s[2*i+1] = char(lo);            \n        }\n        return string(s);\n    }\n    function char(bytes1 b) internal pure returns (bytes1 c) {\n        if (uint8(b) < 10) return bytes1(uint8(b) + 0x30);\n        else return bytes1(uint8(b) + 0x57);\n    }\n}",
